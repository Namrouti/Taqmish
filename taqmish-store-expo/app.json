{
  "expo": {
    "name": "Taqmish Store",
    "slug": "taqmish-store-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "../taqmish-expo/assets/images/icon.png",
    "scheme": "taqmishstoreexpo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "../taqmish-expo/assets/images/android-icon-foreground.png",
        "backgroundImage": "../taqmish-expo/assets/images/android-icon-background.png",
        "monochromeImage": "../taqmish-expo/assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "../taqmish-expo/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Taqmish Store to upload product photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
