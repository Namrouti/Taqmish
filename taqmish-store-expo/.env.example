EXPO_PUBLIC_KIMI_BASE_URL=https://api.moonshot.ai/v1
EXPO_PUBLIC_KIMI_MODEL=kimi-k2.5

# Do not put your Moonshot API key in EXPO_PUBLIC_* variables for production apps.
# Call Kimi through your own backend or serverless proxy and keep the secret there.
# Example:
# EXPO_PUBLIC_KIMI_PROXY_URL=https://your-domain.example/api/kimi/chat
