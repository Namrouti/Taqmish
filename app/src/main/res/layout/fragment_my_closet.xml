<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="خزانتي"
            android:textAppearance="?android:textAppearanceLarge"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="أضف قطعة جديدة بالكاميرا سيتم إزالة الخلفية وتصنيفها تلقائيا في القسم المناسب."
            android:textAppearance="?android:textAppearanceSmall"
            android:paddingBottom="16dp" />

        <Button
            android:id="@+id/capturePieceButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="أضف قطعة بالكاميرا"
            android:backgroundTint="@color/teal_700"
            android:textColor="@android:color/white"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <ImageView
            android:id="@+id/previewImageView"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"
            android:background="@android:color/darker_gray"
            android:visibility="gone"
            android:contentDescription="Preview" />

        <TextView
            android:id="@+id/previewStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="لم يتم التقاط صورة بعد"
            android:textAppearance="?android:textAppearanceSmall"
            android:paddingTop="8dp"
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="عرض الخزانة حسب النوع"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="true"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/filterAllButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الكل"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/filterTopButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أعلى"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/filterBottomButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أسفل"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/filterShoesButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أحذية"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/filterAccessoriesButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="إكسسوارات"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/filterBagButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="حقائب"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/currentFilterText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="عرض: الكل"
            android:textAppearance="?android:textAppearanceSmall"
            android:paddingBottom="12dp" />

        <TextView
            android:id="@+id/savedItemsEmptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="لا توجد قطع في الخزانة بعد. أضف قطعة باستخدام الكاميرا."
            android:textAppearance="?android:textAppearanceSmall"
            android:visibility="gone"
            android:paddingBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/closetRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="220dp"
            android:paddingBottom="16dp" />

        <Button
            android:id="@+id/saveCapturedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="حفظ القطعة في الخزانة"
            android:backgroundTint="@color/teal_700"
            android:textColor="@android:color/white"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
