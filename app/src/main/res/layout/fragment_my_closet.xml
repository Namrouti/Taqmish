<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_variant"
    android:padding="12dp">

    <!-- Camera capture section -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/captureCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/capturePieceButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="التقط قطعة"
                android:textAllCaps="false"
                app:backgroundTint="@color/primary"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_camera"
                app:iconGravity="textStart" />

            <ImageView
                android:id="@+id/previewImageView"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Preview" />

            <TextView
                android:id="@+id/previewStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="لم يتم التقاط صورة بعد"
                android:textAlignment="center"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveCapturedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:text="حفظ القطعة"
                android:textAllCaps="false"
                android:visibility="gone"
                app:backgroundTint="@color/accent"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Filter section -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/filterCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/captureCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/currentFilterText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="عرض: الكل"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/filterAllButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الكل"
                        android:textSize="12sp"
                        app:chipBackgroundColor="@color/primary"
                        app:chipMinHeight="32dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/filterTopButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أعلى"
                        android:textSize="12sp"
                        app:chipMinHeight="32dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/filterBottomButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أسفل"
                        android:textSize="12sp"
                        app:chipMinHeight="32dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/filterShoesButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أحذية"
                        android:textSize="12sp"
                        app:chipMinHeight="32dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/filterAccessoriesButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="إكسسوارات"
                        android:textSize="12sp"
                        app:chipMinHeight="32dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/filterBagButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="حقائب"
                        android:textSize="12sp"
                        app:chipMinHeight="32dp" />

                </com.google.android.material.chip.ChipGroup>

            </HorizontalScrollView>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Closet items grid -->
    <TextView
        android:id="@+id/savedItemsEmptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="لا توجد عناصر في الخزانة بعد"
        android:textAlignment="center"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/filterCard" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/closetRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filterCard" />

</androidx.constraintlayout.widget.ConstraintLayout>
