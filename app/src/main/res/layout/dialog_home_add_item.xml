<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/dialogPreviewImage"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:adjustViewBounds="true"
            android:background="@android:color/white"
            android:scaleType="fitCenter"
            android:src="@drawable/placeholder_image" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="اسم القطعة"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/dialogItemTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="مثال: White Overshirt" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="نوع العرض في الهوم"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/dialogItemTypeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="ستايل القطعة"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/dialogItemCategorySpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/dialogColorsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Dominant colors: -" />

        <ProgressBar
            android:id="@+id/dialogSaveProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/dialogChooseImageButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اختيار صورة" />

            <Button
                android:id="@+id/dialogRetakeButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="تصوير" />

            <Button
                android:id="@+id/dialogSaveItemButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="حفظ" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
