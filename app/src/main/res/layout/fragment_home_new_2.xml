<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_variant"
    android:orientation="vertical">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Outfit Progress + Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/outfitStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tap items below to build your outfit"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <ProgressBar
            android:id="@+id/outfitProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="80dp"
            android:layout_height="6dp"
            android:max="7"
            android:progress="0"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="@color/outline" />

        <Switch
            android:id="@+id/genderSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="M/F"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:thumbTint="@color/accent" />

        <ImageButton
            android:id="@+id/captureImageButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_button_primary"
            android:contentDescription="Add item"
            android:padding="6dp"
            android:src="@drawable/ic_camera"
            app:tint="@color/white" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Color Range"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/colorRangeValueText"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="120"
                    android:textColor="@color/accent"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/colorRangeHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Controls color matching from ColorHelper"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />

            <SeekBar
                android:id="@+id/colorRangeSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:max="255"
                android:progress="120" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Outfit Preview Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/slotTop"
                        android:layout_width="0dp"
                        android:layout_height="158dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_outfit_slot"
                        android:padding="3dp">

                        <ImageView
                            android:id="@+id/selectedTop"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:adjustViewBounds="true"
                            android:scaleType="centerCrop" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/slotBottom"
                        android:layout_width="0dp"
                        android:layout_height="158dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_outfit_slot"
                        android:padding="3dp">

                        <ImageView
                            android:id="@+id/selectedBottom"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:adjustViewBounds="true"
                            android:scaleType="centerCrop" />
                    </FrameLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/slotShoes"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_outfit_slot"
                        android:padding="3dp">

                        <ImageView
                            android:id="@+id/selectedShoes"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:adjustViewBounds="true"
                            android:scaleType="centerCrop" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="88dp"
                        android:layout_height="120dp"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/slotWatch"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_outfit_slot"
                            android:padding="3dp">

                            <ImageView
                                android:id="@+id/selectedWatch"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:adjustViewBounds="true"
                                android:scaleType="centerCrop" />
                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/slotAccessories"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_marginTop="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_outfit_slot"
                            android:padding="3dp">

                            <ImageView
                                android:id="@+id/selectedAccessories"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:adjustViewBounds="true"
                                android:scaleType="centerCrop" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/slotHat"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_outfit_slot"
                        android:padding="3dp">

                        <ImageView
                            android:id="@+id/selectedHat"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:adjustViewBounds="true"
                            android:scaleType="centerCrop" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/slotBag"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_outfit_slot"
                        android:padding="3dp">

                        <ImageView
                            android:id="@+id/selectedBag"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:adjustViewBounds="true"
                            android:scaleType="centerCrop" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Action Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/suggestOutfitButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Suggest"
            android:textAllCaps="false"
            android:textSize="11sp"
            app:backgroundTint="@color/accent"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_color"
            app:iconGravity="textStart"
            app:iconSize="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addToCalendarButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Calendar"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            android:textSize="11sp"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_calendar"
            app:iconGravity="textStart"
            app:iconSize="16dp"
            app:iconTint="@color/primary"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveToClosetButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Save"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            android:textSize="11sp"
            app:cornerRadius="10dp"
            app:icon="@drawable/closet"
            app:iconGravity="textStart"
            app:iconSize="16dp"
            app:iconTint="@color/primary"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearOutfitButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Clear"
            android:textAllCaps="false"
            android:textColor="@color/accent"
            android:textSize="11sp"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_clearall"
            app:iconGravity="textStart"
            app:iconSize="16dp"
            app:iconTint="@color/accent"
            app:strokeColor="@color/accent"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <!-- Category Filter Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/categoryChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="6dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="All"
                app:chipMinHeight="32dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTop"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tops"
                app:chipMinHeight="32dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBottom"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bottoms"
                app:chipMinHeight="32dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipShoes"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shoes"
                app:chipMinHeight="32dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAccessories"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accessories"
                app:chipMinHeight="32dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBags"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bags"
                app:chipMinHeight="32dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipWatch"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Watch"
                app:chipMinHeight="32dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHat"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hat"
                app:chipMinHeight="32dp" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Closet Items Label + Count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="12dp"
        android:paddingBottom="2dp">

        <TextView
            android:id="@+id/closetSectionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SiteClosets"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/itemCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 items"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Closet Items RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="false"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="12dp" />

</LinearLayout>
</LinearLayout>
