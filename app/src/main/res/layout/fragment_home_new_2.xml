<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/fragmentTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="تنسيق الأزياء بحسب نظرية الألوان"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <Switch
            android:id="@+id/genderSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ذكر / أنثى"
            android:textColor="#444444" />

        <ImageButton
            android:id="@+id/captureImageButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="end"
            android:src="@drawable/ic_camera"
            android:background="@null"
            android:contentDescription="إضافة قطعة جديدة" />
    </LinearLayout>

    <TextView
        android:id="@+id/outfitStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="اختر قطعًا من خزانة الملابس أو اضغط زر اقتراح زي.">
    </TextView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:orientation="horizontal"
        android:paddingTop="12dp">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_auth_card"
            android:padding="10dp">

            <ImageView
                android:id="@+id/selectedTop"
                android:layout_width="120dp"
                android:layout_height="150dp"
                android:layout_gravity="center_horizontal"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/toppart" />

            <ImageView
                android:id="@+id/selectedBottom"
                android:layout_width="120dp"
                android:layout_height="150dp"
                android:layout_gravity="center_horizontal|bottom"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/down_48" />

            <ImageView
                android:id="@+id/selectedShoes"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="bottom|start"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/shoes" />

            <ImageView
                android:id="@+id/selectedWatch"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="top|end"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/watch" />

            <ImageView
                android:id="@+id/selectedAccessories"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_gravity="center|end"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/jewerly" />

            <ImageView
                android:id="@+id/selectedHat"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_gravity="top|start"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_image" />

            <ImageView
                android:id="@+id/selectedBag"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="bottom|end"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/bags_48" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="12dp">

            <Button
                android:id="@+id/suggestOutfitButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اقتراح زي" />

            <Button
                android:id="@+id/addToCalendarButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="إضافة إلى التقويم" />

            <Button
                android:id="@+id/clearOutfitButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="مسح الزي" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="اختر إصطفافًا من القطع التالية لتنسيق خزانة متوافق:"
        android:textStyle="bold"
        android:paddingTop="12dp"
        android:textColor="#444" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_marginTop="8dp" />

</LinearLayout>